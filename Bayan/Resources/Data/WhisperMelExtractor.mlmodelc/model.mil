            tensor<fp32, []> var_42 = reduce_max(keep_dims = var_42_keep_dims_0, x = mul_0)[name = tensor<string, []>("op_42")];
            tensor<fp32, []> var_44 = const()[name = tensor<string, []>("op_44"), val = tensor<fp32, []>(0x1p+3)];
            tensor<fp32, []> var_45 = sub(x = var_42, y = var_44)[name = tensor<string, []>("op_45")];
