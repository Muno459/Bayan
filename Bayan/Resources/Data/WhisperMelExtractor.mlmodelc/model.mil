            tensor<fp32, [80, 3001]> maximum_0 = maximum(x = minimum_0, y = var_45)[name = tensor<string, []>("maximum_0")];
            tensor<fp32, []> var_49 = const()[name = tensor<string, []>("op_49"), val = tensor<fp32, []>(0x1p+2)];
            tensor<fp32, [80, 3001]> var_50 = add(x = maximum_0, y = var_49)[name = tensor<string, []>("op_50")];
            tensor<fp32, []> _inversed_mel_y_0 = const()[name = tensor<string, []>("_inversed_mel_y_0"), val = tensor<fp32, []>(0x1p-2)];
            tensor<fp32, [80, 3001]> _inversed_mel = mul(x = var_50, y = _inversed_mel_y_0)[name = tensor<string, []>("_inversed_mel")];
